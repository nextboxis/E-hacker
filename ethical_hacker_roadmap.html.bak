            </div>

            <!-- TAB 4: CHANNEL DIRECTORY -->
            <div id="tab-resources" class="tab-panel">
                <p style="color: var(--text-secondary); margin-bottom: 35px; font-size: 1.05rem;">A directory of key YouTube channels, platforms, and learning portals referenced in our roadmap stages.</p>
                
                <div class="channels-grid">
                    
                    <div class="channel-card">
